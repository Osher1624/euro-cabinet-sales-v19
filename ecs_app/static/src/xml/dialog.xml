<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <!-- Widen the product configurator dialog to 75% of viewport width -->
    <t t-inherit="web.Dialog" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('modal-dialog')]" position="attributes">
            <attribute name="style">max-width: 75% !important;</attribute>
        </xpath>
    </t>
</templates>
