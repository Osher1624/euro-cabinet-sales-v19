<odoo>
    <record id="view_task_form_inherit_approval" model="ir.ui.view">
        <field name="name">project.task.form.approval</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2" />
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <field name="approved_estimation" invisible="1" />
                <button
                    name="action_approve_task_estimation"
                    type="object"
                    string="Approve Estimation"
                    class="btn-primary"
                    invisible="[('approved_estimation', '=', True)]"
                />
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field
                    name="estimated_hours"
                    widget="float_time"
                    readonly="[('approved_estimation', '=', True)]"
                />
            </xpath>
            <xpath expr="//field[@name='description']" position="attributes">
                <attribute
                    name="attrs"
                >{'readonly': [('approved_estimation', '=', True)]}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
