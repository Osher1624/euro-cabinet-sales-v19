<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="mrp_bom_form_view" model="ir.ui.view">
        <field name="name">mrp.bom.form</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view" />
        <field name="arch" type="xml">
            <xpath
                expr="//field[@name='bom_line_ids']/tree/field[@name='sequence']"
                position="after"
            >
                <field
                    optional="show"
                    name="bom_line_category"
                    string="Line Category"
                />
            </xpath>
            <xpath
                expr="//field[@name='bom_line_ids']/tree/field[@name='product_id']"
                position="after"
            >
                <field optional="show" name="note" string="Note" />
            </xpath>
            <xpath
                expr="//field[@name='bom_line_ids']/tree/field[@name='attachments_count']"
                position="attributes"
            >
                <attribute name="string">Attach Count</attribute>
            </xpath>
            <xpath
                expr="//form[1]/sheet[1]/notebook[1]/page[@name='components']/field[@name='bom_line_ids']/tree[1]"
                position="after"
            >
                <form string="BoM Lines" create="0" edit="0">
                    <sheet>
                        <group>
                            <group string="Component">
                                <field name="product_id" />
                                <field name="parent_product_tmpl_id" invisible="1" />
                                <label for="product_qty" string="Quantity" />
                                <div class="o_row" name="studio_div_eb877d">
                                    <field name="product_qty" />
                                    <field
                                        name="product_uom_category_id"
                                        invisible="1"
                                    />
                                    <field
                                        name="product_uom_id"
                                        options="{'no_open':True,'no_create':True}"
                                        groups="uom.group_uom"
                                    />
                                </div>
                                <field
                                    name="possible_bom_product_template_attribute_value_ids"
                                    invisible="1"
                                />
                                <field
                                    name="bom_product_template_attribute_value_ids"
                                    widget="many2many_tags"
                                    options="{'no_create': True}"
                                    groups="product.group_product_variant"
                                />
                            </group>
                            <group string="Operation">
                                <field name="company_id" invisible="1" />
                                <field name="sequence" groups="base.group_no_one" />
                                <field name="allowed_operation_ids" invisible="1" />
                                <field
                                    name="operation_id"
                                    groups="mrp.group_mrp_routings"
                                />
                            </group>
                        </group>
                    </sheet>
                </form>
            </xpath>

        </field>
    </record>


    <record id="mrp_bom_tree_view" model="ir.ui.view">
        <field name="name">mrp.bom.tree</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_tree_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sequence']" position="after">
                <field name="id" optional="show" />
                <field name="bom_line_ids" optional="show" />
                <field name="create_date" optional="show" />
                <field name="write_date" optional="show" />
                <field name="operation_ids" optional="show" />
            </xpath>
            <xpath expr="//field[@name='product_tmpl_id']" position="after">
                <field name="display_name" optional="show" />
            </xpath>
        </field>
    </record>

    <record id="mrp_bom_line_view_tree" model="ir.ui.view">
        <field name="name">mrp_bom_line_view_tree</field>
        <field name="model">mrp.bom.line</field>
        <field name="arch" type="xml">
            <tree multi_edit="1" default_order="product_tmpl_id, id" create="false">
                <field name="bom_id" readonly="1" string="BoM" />
                <field name="company_id" invisible="1" />
                <field name="sequence" widget="handle" />
                <field name="bom_line_category" optional="show" />
                <field name="product_id" readonly="1" />
                <field name="product_tmpl_id" invisible="1" />
                <field name="product_qty" required="0" />
                <field name="product_uom_category_id" invisible="1" />
                <field name="parent_product_tmpl_id" invisible="1" />
                <field
                    name="product_uom_id"
                    options="{'no_open':True,'no_create':True}"
                    groups="uom.group_uom"
                />
                <field
                    name="possible_bom_product_template_attribute_value_ids"
                    invisible="1"
                />
                <field
                    name="bom_product_template_attribute_value_ids"
                    optional="show"
                    widget="many2many_tags"
                    options="{'no_create': True}"
                    attrs="{'column_invisible': [('parent.product_id', '!=', False)]}"
                    groups="product.group_product_variant"
                />
                <field name="allowed_operation_ids" invisible="1" />
                <field
                    name="operation_id"
                    groups="mrp.group_mrp_routings"
                    optional="hidden"
                    attrs="{'column_invisible': [('parent.type','not in', ('normal', 'phantom'))]}"
                    options="{'no_quick_create':True,'no_create_edit':True}"
                />
                <field name="manual_consumption_readonly" invisible="1" />
                <field
                    name="manual_consumption"
                    optional="hide"
                    width="1.0"
                    attrs="{'readonly': [('manual_consumption_readonly', '=', True)]}"
                    force_save="1"
                />
            </tree>
        </field>
    </record>

    <record id="mrp_bom_line_search_view" model="ir.ui.view">
        <field name="name">mrp.bom.line.search</field>
        <field name="model">mrp.bom.line</field>
        <field name="arch" type="xml">
            <search>
                <group expand='0' string='Group by...'>
                    <filter
                        string="BoM"
                        name="bom_id"
                        context="{'group_by': 'bom_id'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record id="mrp_bom_line_action" model="ir.actions.act_window">
        <field name="name">BoM Components</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mrp.bom.line</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                   (0, 0, {'view_mode': 'tree', 'view_id': ref('ecs_app.mrp_bom_line_view_tree')})]"
        />
        <field name="view_mode">tree</field>
        <field name="context">{
            'search_default_bom_id': 1,
            }
        </field>
    </record>

    <menuitem
        id="mrp_bom_line_menu"
        parent="mrp.menu_mrp_bom"
        action="mrp_bom_line_action"
        sequence="3"
    />

</odoo>
