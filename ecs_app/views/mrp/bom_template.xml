<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- BoM Template Form View -->
    <record id="mrp_bom_template_view_form" model="ir.ui.view">
        <field name="name">mrp.bom.template.form</field>
        <field name="model">mrp.bom.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="is_a_template" invisible="1" />
                    <field name="is_readonly" invisible="1" />
                    <button
                        name="process_boms"
                        type="object"
                        string="Process BoM"
                        invisible="['|', ('is_readonly', '=', True), ('is_a_template', '=', True)]"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" invisible="1" />
                        <widget
                            name="web_ribbon"
                            title="Archived"
                            bg_color="bg-danger"
                            invisible="[('active', '=', True)]"
                        />
                        <button
                            name="toggle_active"
                            type="object"
                            groups="base.group_user"
                            class="oe_stat_button"
                            icon="fa-archive"
                            invisible="[('is_a_template', '!=', True)]"
                        >
                            <field
                                name="active"
                                widget="boolean_button"
                                options='{"terminology": "archive"}'
                                invisible="1"
                            />
                        </button>
                        <button
                            class="oe_stat_button"
                            type="object"
                            name="action_view_mrp_bom"
                            icon="fa-flask"
                            invisible="[('bom_count', '=', 0)]"
                        >
                            <field
                                string="View BoM"
                                name="bom_count"
                                widget="statinfo"
                            />
                        </button>
                    </div>
                    <div
                        class="oe_title"
                        invisible="[('is_a_template', '!=', True)]"
                    >
                        <h1
                            invisible="[('id', '!=', False)]"
                        >New BoM Template</h1>
                        <h1>
                            <field
                                name="name"
                                readonly="[('is_a_template', '=', True)]"
                            />
                        </h1>
                    </div>
                    <group>
                        <field
                            name="bom_template_id"
                            domain="[('is_a_template', '=', True)]"
                            options="{'no_create_edit': True,'no_create': True, 'no_quick_create': True, 'no_open': True}"
                            readonly="[('id', '!=', False)]"
                            invisible="[('is_a_template', '=', True)]"
                            required="[('is_a_template', '!=', True)]"
                        />
                        <field
                            name="product_tmpl_ids"
                            widget="many2many_tags"
                            options="{'no_create_edit': True,'no_create': True, 'no_quick_create': True, 'no_open': True}"
                            readonly="[('bom_count', '!=', 0)]"
                            invisible="[('is_a_template', '=', True)]"
                            required="[('is_a_template', '!=', True)]"
                        />
                    </group>
                    <notebook>
                        <page string="Components" name="components">
                            <field
                                name="bom_template_line_ids"
                                readonly="[('is_readonly', '=', True)]"
                            >
                                <list>
                                    <field
                                        name="product_id"
                                        required="1"
                                        style="width=45%"
                                        domain="[('id', '!=', ref_product_id)]"
                                        options="{'no_edit': True, 'no_create': True, 'no_open': True}"
                                    />
                                    <field
                                        name="ref_product_id"
                                        invisible="not context.get('default_is_a_template', False)"
                                        style="width=45%"
                                        domain="[('id', '!=', product_id)]"
                                        options="{'no_edit': True, 'no_create': True, 'no_open': True}"
                                    />
                                    <field
                                        name="qty"
                                        required="1"
                                        style="width=10%"
                                        string="Default QTY"
                                    />
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field
                                                name="product_id"
                                                domain="[('id', '!=', ref_product_id)]"
                                                options="{'no_create_edit': True,'no_create': True, 'no_quick_create': True, 'no_open': True}"
                                            />
                                            <field
                                                name="ref_product_id"
                                                invisible="not context.get('default_is_a_template', False)"
                                                domain="[('id', '!=', product_id)]"
                                                options="{'no_create_edit': True,'no_create': True, 'no_quick_create': True, 'no_open': True}"
                                            />
                                            <field name="qty" string="Default QTY" />
                                        </group>
                                        <field
                                            name="attribute_value_setup_ids"
                                            widget="one2many"
                                            invisible="not context.get('default_is_a_template', False)"
                                            context="{'show_attribute': False}"
                                        >
                        <list editable="bottom">
                            <field
                                                    name="attribute_id"
                                                    options="{'no_create_edit': True,'no_create': True, 'no_quick_create': True, 'no_open': True}"
                                                />
                            <field
                                                    name="value_ids"
                                                    domain="[('attribute_id', '=', attribute_id)]"
                                                    widget="many2many_tags"
                                                    options="{'no_create_edit': True,'no_create': True, 'no_quick_create': True, 'no_open': True, 'color_field': 'color'}"
                                                    context="{'default_attribute_id': attribute_id, 'show_attribute': False}"
                                                />
                        </list>
                    </field>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page
                            name="ref_qty_bom"
                            string="Reference QTY BoM"
                            invisible="[('bom_count', '&lt;', 1)]"
                        >
                            <field name="ref_qty_bom_ids" readonly="1">
                                <list>
                                    <field name="product_tmpl_id" string="BoM" />
                                </list>
                            </field>


                        </page>
                        <page
                            name="default_qty_bom"
                            string="Default QTY BoM"
                            invisible="[('bom_count', '&lt;', 1)]"
                        >
                            <field name="default_qty_bom_ids" readonly="1">
                                <list>
                                    <field name="product_tmpl_id" string="BoM" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- BoM Template Tree View -->
    <record id="mrp_bom_template_view_tree" model="ir.ui.view">
        <field name="name">mrp.bom.template.tree</field>
        <field name="model">mrp.bom.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="is_a_template" invisible="1" />
                <field
                    name="product_tmpl_ids"
                    widget="many2many_tags"
                    invisible="context.get('default_is_a_template', False)"
                />
                <field
                    name="bom_ids"
                    widget="many2many_tags"
                    invisible="context.get('default_is_a_template', False)"
                />
            </list>
        </field>
    </record>

    <!-- BoM Template Search View -->
    <record id="mrp_bom_template_view_search" model="ir.ui.view">
        <field name="name">mrp.bom.template.search</field>
        <field name="model">mrp.bom.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="product_tmpl_ids" />
                <filter
                    string="Archived"
                    name="inactive"
                    domain="[('active', '=', False)]"
                />
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_mrp_bom_template" model="ir.actions.act_window">
        <field name="name">BoM Templates</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mrp.bom.template</field>
        <field name="view_mode">list,form</field>
        <field
            name="context"
        >{'default_is_a_template': 1, 'default_is_readonly': 0}</field>
        <field name="domain">[('is_a_template', '=', True)]</field>
    </record>

    <record id="action_create_mrp_bom" model="ir.actions.act_window">
        <field name="name">Create BoMs</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mrp.bom.template</field>
        <field name="view_mode">list,form</field>
        <field
            name="context"
        >{'default_is_a_template': 0, 'default_is_readonly': 1}</field>
        <field name="domain">[('is_a_template', '!=', True)]</field>
    </record>


    <!-- Menu Item -->
    <menuitem
        id="menu_create_mrp_bom"
        action="action_create_mrp_bom"
        parent="mrp.menu_mrp_bom"
        sequence="10"
    />
    <menuitem
        id="menu_mrp_bom_template"
        action="action_mrp_bom_template"
        parent="mrp.menu_mrp_configuration"
        sequence="10"
    />

</odoo>
