<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="import_bom_lines_view_form" model="ir.ui.view">
        <field name="name">import_bom_lines_view_form</field>
        <field name="model">import.bom.lines</field>
        <field name="arch" type="xml">
            <form string="import_bom_lines_form">
                <sheet>
                    <group>
                        <field name="name" invisible="1" />
                        <field name="file" filename="name" />
                    </group>
                </sheet>
                <footer>
                    <button
                        name="import_file"
                        string="Import"
                        type="object"
                        default_focus="1"
                        class="oe_highlight"
                    />
                    <button
                        special="cancel"
                        string="Close"
                        type="object"
                        class="btn-primary"
                    />
                </footer>
            </form>
        </field>
    </record>

    <record id="import_bom_lines_action" model="ir.actions.act_window">
        <field name="name">Import BOM Lines</field>
        <field name="res_model">import.bom.lines</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="import_bom_lines_view_form" />
        <field name="context">{}</field>
        <field name="target">new</field>
    </record>
    <menuitem
        id="import_bom_lines_menu"
        parent="mrp.menu_mrp_bom"
        groups="product.group_product_variant"
        action="import_bom_lines.import_bom_lines_action"
        sequence="14"
    />

</odoo>
